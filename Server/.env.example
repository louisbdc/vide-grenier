# Copier en .env et renseigner
PORT=8080
# Mongo doit être en replica set (même mono-nœud) pour les Change Streams.
MONGO_URL=mongodb://127.0.0.1:27017/videgrenier?replicaSet=rs0
# Secret de signature des jetons (générer une valeur longue et aléatoire)
JWT_SECRET=change-me-with-a-long-random-string
# Clé de l'API REST DATAtourisme (header X-API-Key)
DATATOURISME_API_KEY=
# Stripe : publication d'une annonce = 5 €. Utilise des clés de TEST d'abord.
# Recommandé : une clé restreinte (rk_...) limitée aux PaymentIntents.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Répertoire de stockage des photos (déjà floutées côté client)
PHOTOS_DIR=./data/photos
# Origine autorisée pour CORS (l'app mobile n'en a pas besoin ; utile pour un futur web)
CORS_ORIGIN=*
